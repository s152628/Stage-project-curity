{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki datasource",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    }
  ],
  "title": "OpenLDAP Security Monitor — {{ env }}",
  "uid": "openldap-security-{{ env }}",
  "description": "Security monitoring voor OpenLDAP in namespace {{ namespace }}.",
  "tags": ["openldap", "security", "loki", "{{ env }}"],
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "interval",
        "label": "Rate Interval",
        "type": "custom",
        "query": "1m,2m,5m,10m,15m,30m",
        "current": { "text": "2m", "value": "2m" },
        "options": [
          { "text": "1m",  "value": "1m",  "selected": false },
          { "text": "2m",  "value": "2m",  "selected": true  },
          { "text": "5m",  "value": "5m",  "selected": false },
          { "text": "10m", "value": "10m", "selected": false },
          { "text": "15m", "value": "15m", "selected": false },
          { "text": "30m", "value": "30m", "selected": false }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "count_range",
        "label": "Count Range",
        "type": "custom",
        "query": "15m,30m,1h,3h,6h,12h,24h",
        "current": { "text": "1h", "value": "1h" },
        "options": [
          { "text": "15m", "value": "15m", "selected": false },
          { "text": "30m", "value": "30m", "selected": false },
          { "text": "1h",  "value": "1h",  "selected": true  },
          { "text": "3h",  "value": "3h",  "selected": false },
          { "text": "6h",  "value": "6h",  "selected": false },
          { "text": "12h", "value": "12h", "selected": false },
          { "text": "24h", "value": "24h", "selected": false }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Failed Authentication Attempts (err=49)",
      "description": "Rate van failed BIND operaties. err=49 = Invalid credentials. Spikes wijzen op brute force of credential stuffing.",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"err=49\" [$interval]))",
          "legendFormat": "Failed BINDs/s",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 2,
      "title": "LDAP Operations per Type",
      "description": "Uitsplitsing van alle LDAP operaties: BIND, SRCH, ADD, DEL, MOD, UNBIND.",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (operation) (rate({app=\"openldap\", namespace=\"{{ namespace }}\"} | regexp `op=\\d+ (?P<operation>BIND|SRCH|ADD|DEL|MOD|UNBIND)` | __error__=\"\" [$interval]))",
          "legendFormat": "{{operation}}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 3,
      "title": "Totaal Failed Logins",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"err=49\" [$count_range]))",
          "legendFormat": "Failed logins",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 4,
      "title": "Totaal Anonieme BINDs",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 4, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"BIND anonymous\" [$count_range]))",
          "legendFormat": "Anonieme BINDs",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "orange", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 5,
      "title": "Unrecognized Controls",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 8, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"unrecognized control\" [$count_range]))",
          "legendFormat": "Unrecognized controls",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "orange", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 6,
      "title": "Root Base Recon Searches",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 12, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"base=\\\"\\\"\" |= \"scope=0\" [$count_range]))",
          "legendFormat": "Root searches",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 100 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 7,
      "title": "Succesvolle Logins",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 16, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(count_over_time({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"RESULT tag=97 err=0\" [$count_range]))",
          "legendFormat": "Succesvolle logins",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 8,
      "title": "Top IPs met Failed Logins",
      "description": "IP-adressen met de meeste failed BIND pogingen. Hoge waarden voor één IP = mogelijke brute force.",
      "type": "bargauge",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, sum by (ip) (count_over_time({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"err=49\" | regexp `ACCEPT from IP=(?P<ip>[0-9.]+):` | __error__=\"\" [$count_range])))",
          "legendFormat": "{{ip}}",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 9,
      "title": "Anonieme BIND pogingen over tijd",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"BIND anonymous\" [$interval]))",
          "legendFormat": "Anonymous BINDs/s",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 10,
      "title": "Root Base Reconnaissance over tijd",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"base=\\\"\\\"\" |= \"scope=0\" [$interval]))",
          "legendFormat": "Root searches/s",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 11,
      "title": "Unrecognized Controls over tijd",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"unrecognized control\" [$interval]))",
          "legendFormat": "Unrecognized controls/s",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "yellow" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 12,
      "title": "Gezochte gebruikers (uid) — Top 20",
      "description": "Welke uid's het meest opgezocht worden. Verdacht als onbekende uid's frequent voorkomen.",
      "type": "table",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 10 },
      "targets": [
        {
          "expr": "topk(20, sum by (uid) (count_over_time({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"filter=\" | regexp `filter=\"\\(uid=(?P<uid>[^)]+)\\)\"` | __error__=\"\" [$count_range])))",
          "legendFormat": "{{uid}}",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Aantal searches" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 10 },
                    { "color": "red", "value": 50 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Aantal searches", "desc": true }]
      }
    },
    {
      "id": 13,
      "title": "Failed Login Gebruikers",
      "description": "Welke DN's falen bij authenticatie. Toont mogelijke targets van een aanval.",
      "type": "table",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 10 },
      "targets": [
        {
          "expr": "topk(20, sum by (dn) (count_over_time({app=\"openldap\", namespace=\"{{ namespace }}\"} |= \"err=49\" | regexp `BIND dn=\"(?P<dn>[^\"]+)\"` | __error__=\"\" [$count_range])))",
          "legendFormat": "{{dn}}",
          "refId": "A",
          "queryType": "instant"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Aantal failures" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 3 },
                    { "color": "red", "value": 10 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Aantal failures", "desc": true }]
      }
    },
    {
      "id": 14,
      "title": "Ruwe LDAP Logs — {{ namespace }}",
      "description": "Live log stream van OpenLDAP in {{ namespace }}.",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 10 },
      "targets": [
        {
          "expr": "{app=\"openldap\", namespace=\"{{ namespace }}\"}",
          "refId": "A",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}