apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ tailscale_hostname }}
  namespace: {{ tailscale_namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: {{ tailscale_hostname }}
  template:
    metadata:
      labels:
        app: {{ tailscale_hostname }}
    spec:
      serviceAccountName: tailscale-bridge-sa
      containers:
      - name: tailscale
        image: {{ tailscale_image }}
        env:
        - name: TS_AUTHKEY
          valueFrom:
            secretKeyRef:
              name: tailscale-auth
              key: TS_AUTHKEY
        - name: TS_EXTRA_ARGS
          value: "--hostname=k8s-infra-bridge"
        securityContext:
          capabilities:
            add:
            - NET_ADMIN
        volumeMounts:
        - name: ts-state
          mountPath: /var/lib/tailscale
      - name: bridge
        image: alpine/socat
        command: ["sh", "-c", "
         socat TCP-LISTEN:8082,fork,reuseaddr TCP:kube-prometheus-stack-grafana.monitoring.svc.cluster.local:80 &
         socat TCP-LISTEN:8081,fork,reuseaddr TCP:argocd-server.argocd.svc.cluster.local:443
         "]
      volumes:
      - name: ts-state
        emptyDir: {}