apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: curity-{{ env }}-stack
  namespace: argocd
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: default
  sources:
    - repoURL: 'https://github.com/s152628/Stage-project-curity.git'
      targetRevision: HEAD
      path: 'confs/{{ env }}'
      ref: my-config
    
    - repoURL: 'https://curityio.github.io/idsvr-helm/'
      targetRevision: '0.13.17'
      chart: idsvr
      helm:
        valueFiles:
          - '$my-config/confs/{{ env }}/values.yaml'

  destination:
    server: 'https://kubernetes.default.svc'
    namespace: curity-{{ env }}

  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - ServerSideApply=true
      - replace=true